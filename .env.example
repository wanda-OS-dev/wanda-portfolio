# WandaSystems Portfolio — Environment Variables
# Copy to .env.local for local development. Never commit .env.local.

# Contact form (optional — if not set, messages are logged to console)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key_here
CONTACT_EMAIL=hello@wandasystems.io

# Site URL (for OG images / sitemap)
NEXT_PUBLIC_SITE_URL=https://wandasystems.io
